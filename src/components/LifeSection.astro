---
import { lifePillars } from '../data/content';
---

<section class="section life-section" data-animate-section="true">
  <div class="wrap life-grid">
    <div class="life-photo reveal">
      <div class="tall">
        <img
          alt="GTA Mavericks athlete showing focus and control during basketball play"
          src="https://gtamavericks.ca/wp-content/uploads/2025/03/Spring-Select-Basketball.jpg"
        />
      </div>
      <div class="short">
        <img
          alt="Young GTA Mavericks players learning together"
          src="https://gtamavericks.ca/wp-content/uploads/2024/11/richmond-hill-basketball.webp"
        />
      </div>
    </div>
    <div class="life-copy reveal">
      <div class="eyebrow">Beyond the scoreboard</div>
      <h2>Basketball builds more than basketball players.</h2>
      <p>
        Being part of a real team teaches kids to show up prepared, listen, bounce back from mistakes, and
        contribute to something bigger than themselves — lessons that stick long after the final buzzer.
      </p>
      <div class="life-pillars">
        {
          lifePillars.map((pillar, i) => (
            <div class="life-pillar reveal reveal-scale" style={`--delay:${i * 70}ms`}>
              <b>{pillar.title}</b>
              <span>{pillar.body}</span>
            </div>
          ))
        }
      </div>
      <div class="coach-voice">
        <strong>Sometimes the coach is the voice that finally lands.</strong>
        <span>
          The right coach becomes another trusted adult reinforcing effort, accountability, resilience, and better
          habits—alongside the parent, not in place of them.
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .life-section {
    background: linear-gradient(160deg, #0b111a, #12192a);
    overflow: hidden;
  }
  .life-section::before {
    content: '';
    position: absolute;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(123, 77, 255, 0.2), transparent 66%);
    right: -280px;
    bottom: -360px;
  }
  .life-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 70px;
    align-items: center;
    position: relative;
  }
  .life-photo {
    display: grid;
    grid-template-columns: 1fr 0.78fr;
    gap: 14px;
    align-items: center;
  }
  .life-photo .tall {
    height: 600px;
    border-radius: 24px;
    overflow: hidden;
  }
  .life-photo .short {
    height: 390px;
    border-radius: 24px;
    overflow: hidden;
  }
  .life-copy h2 {
    font-size: clamp(40px, 5vw, 66px);
    line-height: 0.96;
    letter-spacing: -2.8px;
    margin-top: 16px;
  }
  .life-copy > p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    margin-top: 22px;
  }
  .life-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 28px;
  }
  .life-pillar {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 15px;
    background: rgba(255, 255, 255, 0.035);
  }
  .life-pillar b {
    font-size: 15px;
    display: block;
  }
  .life-pillar span {
    font-size: 12px;
    line-height: 1.5;
    color: var(--muted);
    display: block;
    margin-top: 7px;
  }
  .coach-voice {
    margin-top: 24px;
    padding: 24px;
    border-left: 4px solid var(--blue-2);
    background: rgba(56, 182, 255, 0.07);
    border-radius: 0 14px 14px 0;
  }
  .coach-voice strong {
    font-size: 20px;
    line-height: 1.35;
    display: block;
  }
  .coach-voice span {
    display: block;
    margin-top: 10px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }
  @media (max-width: 980px) {
    .life-grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }
    .life-photo {
      max-width: 720px;
    }
  }
  @media (max-width: 760px) {
    .life-photo {
      grid-template-columns: 1fr 1fr;
    }
    .life-photo .tall {
      height: 440px;
    }
    .life-photo .short {
      height: 310px;
    }
    .life-pillars {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .life-photo .tall {
      height: 380px;
    }
    .life-photo .short {
      height: 270px;
    }
  }
</style>

---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'small';
  target?: '_blank' | '_self';
  arrow?: boolean;
  class?: string;
}

const { href, variant = 'primary', target, arrow = false, class: className } = Astro.props;
const rel = target === '_blank' ? 'noopener' : undefined;
const variantClass = variant === 'primary' ? undefined : variant;
---

<a class:list={['btn', variantClass, className]} href={href} target={target} rel={rel}>
  <slot />
  {
    arrow && (
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    )
  }
</a>

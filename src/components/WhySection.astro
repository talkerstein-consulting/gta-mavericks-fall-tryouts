---
import SectionIntro from './SectionIntro.astro';
import { whyCards } from '../data/content';
---

<section class="section" data-animate-section="true">
  <div class="wrap why-grid">
    <SectionIntro eyebrow="Why players come to tryouts" title="A new season is a chance to find a better fit.">
      <p class="section-intro">
        Choosing a team is a big decision for your family. Tryouts are the best way to see it for yourself — meet
        the coaches, feel the energy, and find out if Mavericks is the right fit before you commit to a season.
      </p>
    </SectionIntro>
    <div class="why-cards">
      {
        whyCards.map((card, i) => (
          <article class="why-card reveal reveal-scale" style={`--delay:${i * 70}ms`}>
            <div class="why-num">{card.num}</div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 70px;
    align-items: end;
  }
  .why-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .why-card {
    padding: 26px;
    border-radius: 18px;
    background: var(--panel);
    border: 1px solid var(--line);
    min-height: 190px;
    transition: 0.2s ease;
  }
  .why-card:hover {
    transform: translateY(-4px);
    border-color: rgba(56, 182, 255, 0.45);
    background: var(--panel-2);
  }
  .why-num {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(56, 182, 255, 0.13);
    color: var(--blue-2);
    display: grid;
    place-items: center;
    font-weight: 900;
  }
  .why-card h3 {
    font-size: 20px;
    line-height: 1.15;
    margin-top: 22px;
  }
  .why-card p {
    color: var(--muted);
    line-height: 1.55;
    font-size: 14px;
    margin-top: 10px;
  }
  @media (max-width: 980px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }
  }
  @media (max-width: 760px) {
    .why-cards {
      grid-template-columns: 1fr;
    }
    .why-card {
      min-height: 0;
    }
  }
</style>

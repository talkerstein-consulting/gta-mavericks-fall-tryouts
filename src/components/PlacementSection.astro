---
import SectionIntro from './SectionIntro.astro';
import { placementSteps } from '../data/content';
---

<section class="section" data-animate-section="true">
  <div class="wrap placement-grid">
    <SectionIntro eyebrow="After the tryout" title="A clear outcome for every athlete.">
      <p class="section-intro">The tryout is the front door. The placement process helps families understand what comes next.</p>
      <div class="placement-note">
        <strong>Important:</strong> Registering does not guarantee a Rep roster spot. It guarantees an evaluation
        opportunity and a clear communication about the recommended next step.
      </div>
    </SectionIntro>
    <div class="steps">
      {
        placementSteps.map((step, i) => (
          <article class="step reveal reveal-left" style={`--delay:${i * 70}ms`}>
            <div class="step-no">{step.no}</div>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .placement-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 70px;
    align-items: start;
  }
  .placement-note {
    margin-top: 22px;
    padding: 20px 22px;
    border-radius: 16px;
    border: 1px solid rgba(56, 182, 255, 0.35);
    background: rgba(56, 182, 255, 0.07);
    color: #dcecf7;
    line-height: 1.6;
    font-size: 14px;
  }
  .steps {
    display: grid;
    gap: 12px;
  }
  .step {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 18px;
    padding: 22px;
    border-radius: 16px;
    background: var(--panel);
    border: 1px solid var(--line);
  }
  .step-no {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: linear-gradient(145deg, #0e94d8, #38b6ff);
    color: #031018;
    display: grid;
    place-items: center;
    font-size: 20px;
    font-weight: 900;
  }
  .step h3 {
    font-size: 18px;
  }
  .step p {
    color: var(--muted);
    line-height: 1.55;
    font-size: 14px;
    margin-top: 7px;
  }
  @media (max-width: 980px) {
    .placement-grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }
  }
  @media (max-width: 520px) {
    .step {
      grid-template-columns: 46px 1fr;
      padding: 18px;
      gap: 14px;
    }
    .step-no {
      width: 46px;
      height: 46px;
    }
  }
</style>

---
import { site } from '../data/site';
---

<aside aria-labelledby="quick-contact-title" class="quick-contact reveal reveal-right" id="quick-contact">
  <div class="contact-trust">
    <div class="google-mini">
      <span aria-hidden="true" class="google-g">G</span>
      <span>Trusted by<br />Mavericks families</span>
    </div>
    <div aria-label="Five star parent feedback" class="star-row">★★★★★</div>
  </div>
  <div class="eyebrow">Questions before tryouts?</div>
  <h2 id="quick-contact-title">Talk to the Mavericks team.</h2>
  <p>Tell us about your player. We’ll help you confirm the right age group, session, and pathway before you register.</p>
  <form class="lead-form" id="tryoutLeadForm" novalidate>
    <div class="form-field">
      <label for="parentName">Parent / guardian</label>
      <input autocomplete="name" id="parentName" name="parentName" placeholder="Your name" required type="text" />
    </div>
    <div class="form-field">
      <label for="parentPhone">Phone number</label>
      <input
        autocomplete="tel"
        id="parentPhone"
        inputmode="tel"
        name="parentPhone"
        placeholder="(647) 555-0123"
        required
        type="tel"
      />
    </div>
    <div class="form-field">
      <label for="playerAge">Player age group</label>
      <select id="playerAge" name="playerAge" required>
        <option value="">Choose one</option>
        <option>U9–U11</option>
        <option>U12</option>
        <option>U13</option>
        <option>U14</option>
        <option>U15</option>
        <option>U16–U17</option>
        <option>Not sure</option>
      </select>
    </div>
    <div class="form-field">
      <label for="playerLevel">Current level</label>
      <select id="playerLevel" name="playerLevel" required>
        <option value="">Choose one</option>
        <option>Beginner / Fundamentals</option>
        <option>Recreational</option>
        <option>Select / Development</option>
        <option>Current Rep player</option>
        <option>Not sure</option>
      </select>
    </div>
    <div class="form-field full">
      <label for="leadMessage">Question or context</label>
      <textarea
        id="leadMessage"
        name="message"
        placeholder="Current club, position, experience, or what you need help with..."></textarea>
    </div>
    <button class="btn" type="submit">Send My Tryout Question</button>
    <div aria-live="polite" class="form-status" id="formStatus" role="status"></div>
    <p class="form-privacy">By sending this form, you agree that GTA Mavericks may contact you about tryouts and related basketball programs.</p>
  </form>
  <div class="contact-direct">
    <span>Prefer direct?</span>
    <a href={site.phoneHref}>Call {site.phoneDisplayContact}</a>
    <a href={`mailto:${site.email}`}>Email us</a>
  </div>
</aside>

<style>
  .quick-contact {
    position: relative;
    padding: 28px;
    border-radius: 22px;
    background: linear-gradient(150deg, rgba(13, 20, 31, 0.96), rgba(5, 9, 15, 0.94));
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.48);
    backdrop-filter: blur(18px);
    overflow: hidden;
  }
  .quick-contact::before {
    content: '';
    position: absolute;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    right: -110px;
    top: -130px;
    background: radial-gradient(circle, rgba(56, 182, 255, 0.28), transparent 66%);
    pointer-events: none;
  }
  .contact-trust {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 18px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .google-mini {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.45px;
    text-transform: uppercase;
  }
  .google-g {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: #fff;
    color: #4285f4;
    font-size: 20px;
    font-family: Arial, sans-serif;
    font-weight: 900;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  }
  .star-row {
    color: #fbbc04;
    letter-spacing: 1px;
    font-size: 13px;
    white-space: nowrap;
  }
  .quick-contact h2 {
    font-size: 29px;
    line-height: 1.05;
    letter-spacing: -1px;
    margin-top: 8px;
  }
  .quick-contact > p {
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
    margin-top: 10px;
  }
  .lead-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 20px;
  }
  .form-field {
    display: grid;
    gap: 7px;
    min-width: 0;
  }
  .form-field.full {
    grid-column: 1 / -1;
  }
  .form-field label {
    font-size: 10px;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    font-weight: 900;
    color: #c9d3e0;
  }
  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.065);
    color: #fff;
    border-radius: 11px;
    padding: 13px 13px;
    font: inherit;
    font-size: 16px;
    line-height: 1.25;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .form-field select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #9fb0c4 50%),
      linear-gradient(135deg, #9fb0c4 50%, transparent 50%);
    background-position: calc(100% - 17px) 52%, calc(100% - 12px) 52%;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    padding-right: 38px;
  }
  .form-field option {
    color: #08101c;
    background: #fff;
  }
  .form-field textarea {
    min-height: 86px;
    resize: vertical;
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: #8f9bae;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--blue-2);
    background: rgba(56, 182, 255, 0.08);
    box-shadow: 0 0 0 4px rgba(56, 182, 255, 0.1);
  }
  .lead-form :global(.btn) {
    grid-column: 1 / -1;
    width: 100%;
    border: 0;
    cursor: pointer;
  }
  .form-privacy {
    grid-column: 1 / -1;
    font-size: 10px;
    line-height: 1.45;
    color: #7f8b9d;
  }
  .form-status {
    grid-column: 1 / -1;
    min-height: 18px;
    font-size: 11px;
    color: #a9e4ff;
    font-weight: 700;
  }
  .contact-direct {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 14px;
    font-size: 11px;
    color: #b7c1cf;
  }
  .contact-direct a {
    font-weight: 800;
    color: #fff;
    text-decoration: underline;
    text-decoration-color: rgba(56, 182, 255, 0.45);
    text-underline-offset: 3px;
  }
  @media (max-width: 760px) {
    .quick-contact {
      padding: 23px;
      border-radius: 18px;
    }
    .quick-contact h2 {
      font-size: 25px;
    }
  }
  @media (max-width: 560px) {
    .lead-form {
      grid-template-columns: 1fr;
    }
    .form-field.full,
    .lead-form :global(.btn),
    .form-privacy,
    .form-status {
      grid-column: auto;
    }
    .contact-trust {
      align-items: flex-start;
    }
    .star-row {
      font-size: 11px;
    }
  }
</style>

---
import Button from './Button.astro';
import { site } from '../data/site';
---

<section class="hero" data-animate-section="true" id="top">
  <div aria-hidden="true" class="hero-media">
    <video
      autoplay
      loop
      muted
      playsinline
      poster="/images/mavericks-action-placeholder.webp"
      src={site.heroVideoUrl}></video>
  </div>
  <div class="wrap">
    <div class="hero-top-grid">
      <div class="hero-content reveal in reveal-left">
        <div class="eyebrow">2026–27 Rep Team Selection</div>
        <h1>Earn your place.<span>Find your level.</span></h1>
        <p class="hero-copy">
          Try out for a GTA Mavericks Rep roster and be evaluated for the competitive pathway that best fits your
          game, goals, and family commitment.
        </p>
        <ul aria-label="Tryout highlights" class="hero-list">
          <li>{site.eventDatesShort}, {site.eventYear}</li>
          <li>{site.venue}</li>
          <li>Boys &amp; Girls {site.ageRange}</li>
          <li>{site.fee} per player</li>
        </ul>
        <div class="hero-actions">
          <Button href={site.registrationUrl} target="_blank" arrow>Register for Tryouts — {site.fee}</Button>
          <Button href="#schedule" variant="secondary">Find My Time</Button>
        </div>
        <p class="hero-note">
          Rep roster spots are coach-selected. Athletes who are not placed on Rep may be recommended for Select or
          Fundamentals based on current readiness and commitment.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 860px;
    position: relative;
    display: flex;
    align-items: center;
    isolation: isolate;
    overflow: hidden;
  }
  .hero .wrap {
    position: relative;
    z-index: 2;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -3;
  }
  .hero-media video {
    filter: saturate(0.85) contrast(1.05);
  }
  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        90deg,
        rgba(2, 4, 8, 0.98) 0%,
        rgba(2, 4, 8, 0.82) 38%,
        rgba(2, 4, 8, 0.25) 72%,
        rgba(2, 4, 8, 0.45) 100%
      ),
      linear-gradient(0deg, #05070b 0%, transparent 30%);
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: auto -20% 4% 25%;
    height: 380px;
    background: radial-gradient(circle, rgba(56, 182, 255, 0.18), transparent 68%);
    filter: blur(40px);
    z-index: -2;
  }
  .hero-top-grid {
    padding-top: 116px;
    padding-bottom: 82px;
  }
  .hero-content {
    padding: 0;
    max-width: 760px;
    min-width: 0;
  }
  .hero h1 {
    font-size: clamp(54px, 8vw, 108px);
    line-height: 0.87;
    letter-spacing: -5px;
    text-transform: uppercase;
    font-weight: 900;
    margin-top: 20px;
  }
  .hero h1 span {
    display: block;
    color: var(--blue-2);
  }
  .hero-copy {
    font-size: clamp(17px, 2vw, 22px);
    line-height: 1.55;
    color: #e0e7f1;
    max-width: 680px;
    margin-top: 26px;
    font-weight: 600;
  }
  .hero-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
    list-style: none;
  }
  .hero-list li {
    padding: 10px 13px;
    background: rgba(0, 0, 0, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
    backdrop-filter: blur(14px);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }
  .hero-note {
    margin-top: 17px;
    color: #a9b5c6;
    font-size: 12px;
    line-height: 1.55;
    max-width: 590px;
  }
  @media (max-width: 1100px) {
    .hero h1 {
      font-size: clamp(50px, 7.4vw, 88px);
    }
  }
  @media (max-width: 980px) {
    .hero {
      min-height: 800px;
      align-items: flex-end;
    }
  }
  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      align-items: stretch;
    }
    .hero-top-grid {
      padding-top: 142px;
      padding-bottom: 92px;
    }
  }
  @media (max-width: 760px) {
    .hero {
      align-items: flex-end;
    }
    .hero-top-grid {
      padding-top: 136px;
      padding-bottom: 88px;
    }
    .hero h1 {
      letter-spacing: -3px;
    }
    .hero-media::after {
      background: linear-gradient(0deg, rgba(2, 4, 8, 0.98) 0%, rgba(2, 4, 8, 0.78) 60%, rgba(2, 4, 8, 0.35) 100%);
    }
  }
  @media (max-width: 520px) {
    .hero h1 {
      font-size: 51px;
      letter-spacing: -2.7px;
    }
    .hero-copy {
      font-size: 16px;
    }
    .hero-actions {
      display: grid;
    }
    .hero-actions :global(.btn) {
      width: 100%;
    }
    .hero-list {
      gap: 7px;
    }
    .hero-list li {
      font-size: 11px;
      padding: 8px 10px;
    }
  }
  @media (max-width: 560px) {
    .hero h1 {
      font-size: 46px;
      line-height: 0.9;
    }
    .hero-copy {
      font-size: 15px;
    }
  }
</style>

---
import SectionIntro from './SectionIntro.astro';
import Button from './Button.astro';
import { detailCards, scheduleDays } from '../data/content';
import { site } from '../data/site';
---

<section class="section details-section" data-animate-section="true" id="schedule">
  <div class="wrap">
    <SectionIntro eyebrow="Official details" title="One assigned session. Come ready.">
      <p class="section-intro">
        Players attend the session assigned to their age group. Arrive early enough to check in, change, and be
        ready when the session begins.
      </p>
    </SectionIntro>
    <div class="details-grid">
      {
        detailCards.map((card, i) => (
          <div class="detail-card reveal reveal-scale" style={`--delay:${i * 70}ms`}>
            <div class="detail-label">{card.label}</div>
            <div class="detail-main">{card.main}</div>
            <div class="detail-sub">{card.sub}</div>
          </div>
        ))
      }
    </div>
    <div class="schedule reveal">
      {
        scheduleDays.map((day, i) => (
          <div class="schedule-day reveal reveal-scale" style={`--delay:${i * 70}ms`}>
            <h3>{day.day}</h3>
            {day.rows.map((row) => (
              <div class="sched-row">
                <span class="sched-time">{row.time}</span>
                <span class="sched-tag">{row.tag}</span>
              </div>
            ))}
          </div>
        ))
      }
    </div>
    <div class="reveal" style="text-align:center;margin-top:30px">
      <Button href={site.registrationUrl} target="_blank">Reserve My Tryout Spot</Button>
    </div>
  </div>
</section>

<style>
  .details-section {
    background: #f3f6fb;
    color: #0b1220;
  }
  .details-section :global(.eyebrow) {
    color: #087fc1;
  }
  .details-section :global(.section-intro) {
    color: #5f6d81;
  }
  .details-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 42px;
  }
  .detail-card {
    background: #fff;
    border: 1px solid #dfe6f0;
    border-radius: 18px;
    padding: 24px;
    box-shadow: 0 14px 40px rgba(16, 38, 67, 0.07);
  }
  .detail-label {
    font-size: 10px;
    letter-spacing: 1.7px;
    text-transform: uppercase;
    color: #0b8bd3;
    font-weight: 900;
  }
  .detail-main {
    font-size: 24px;
    font-weight: 900;
    margin-top: 10px;
  }
  .detail-sub {
    font-size: 13px;
    line-height: 1.45;
    color: #69778a;
    margin-top: 7px;
  }
  .schedule {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 18px;
  }
  .schedule-day {
    background: #fff;
    border: 1px solid #dfe6f0;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 14px 40px rgba(16, 38, 67, 0.06);
  }
  .schedule-day h3 {
    font-size: 16px;
    color: #087fc1;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 13px;
  }
  .sched-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 13px 0;
    border-top: 1px solid #e9eef5;
  }
  .sched-row:first-of-type {
    border-top: 0;
  }
  .sched-time {
    font-size: 13px;
    color: #667487;
    font-weight: 700;
  }
  .sched-tag {
    font-size: 12px;
    font-weight: 900;
    border-radius: 999px;
    padding: 7px 10px;
    background: #eef8ff;
    color: #087fc1;
    white-space: nowrap;
  }
  @media (max-width: 980px) {
    .details-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 760px) {
    .schedule {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .details-grid {
      grid-template-columns: 1fr;
    }
    .schedule-day {
      padding: 20px;
    }
    .sched-row {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
